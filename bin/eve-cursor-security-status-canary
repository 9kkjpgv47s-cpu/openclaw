#!/usr/bin/env bash
# Run `cursor-agent status` as a security/auth canary. On failure, retry with
# exponential backoff (2s then 4s) for up to 3 attempts total — transient CLI/API blips only.
# Exits with the last attempt's status. See TOOLS.md "Security status canary (retry)".
set -euo pipefail

if ! command -v cursor-agent >/dev/null 2>&1; then
  echo "eve-cursor-security-status-canary: cursor-agent not on PATH; skip." >&2
  exit 0
fi

delay=2
attempt=1
max=3

while (( attempt <= max )); do
  if cursor-agent status; then
    exit 0
  fi
  if (( attempt == max )); then
    echo "eve-cursor-security-status-canary: all ${max} attempts failed." >&2
    exit 1
  fi
  echo "eve-cursor-security-status-canary: attempt ${attempt} failed; retrying after ${delay}s..." >&2
  sleep "$delay"
  delay=$(( delay * 2 ))
  attempt=$(( attempt + 1 ))
done
